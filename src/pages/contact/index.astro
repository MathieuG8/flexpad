---
import Layout from '../../layouts/Layout.astro';
---

<Layout site title="Contact | FlexPad - BE PRODUCTIVE">
  <div class="page-content">
    <nav class="breadcrumb">
      <a href="/">Accueil</a>
      <span class="separator">/</span>
      <span>Contact</span>
    </nav>

    <main class="content-section">
      <h1 class="page-title reveal">Contactez-nous</h1>
      <p class="page-lead reveal reveal-delay-1">
        Une question sur FlexPad, une demande partenariat ou un retour sur l’interface web ?
        Utilisez le formulaire ou les coordonnées ci-dessous — nous répondons en général sous 48 h ouvrables.
      </p>

      <div class="contact-split">
        <div class="contact-form-card reveal">
          <h2>Envoyer un message</h2>
          <p class="contact-aside-note">
            Ce formulaire ouvre votre client de courriel avec le message prérempli (aucune donnée n’est
            envoyée à un serveur depuis cette page démo).
          </p>
          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <label for="contact-name">Nom *</label>
              <input type="text" id="contact-name" name="name" required placeholder="Votre nom" autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="contact-email">Courriel *</label>
              <input type="email" id="contact-email" name="email" required placeholder="vous@exemple.com" autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="contact-subject">Sujet</label>
              <select id="contact-subject" name="subject">
                <option value="Question générale">Question générale</option>
                <option value="Support technique">Support technique</option>
                <option value="Commande / disponibilité">Commande / disponibilité</option>
                <option value="Autre">Autre</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contact-message">Message *</label>
              <textarea id="contact-message" name="message" required placeholder="Votre message…"></textarea>
            </div>
            <button type="submit" class="btn-primary">Ouvrir le courriel</button>
          </form>
        </div>

        <div>
          <p class="contact-aside-note reveal reveal-delay-1">
            Vous préférez passer directement ? Retrouvez les mêmes informations que sur la page d’accueil,
            avec liens cliquables.
          </p>
          <div class="contact-page-grid">
            <div class="contact-card reveal">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <h4>Créateur</h4>
              <span>Mathieu Goulet</span>
            </div>

            <div class="contact-card reveal reveal-delay-1">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <h4>Téléphone</h4>
              <a href="tel:+15145558888">+1 514 555 8888</a>
            </div>

            <div class="contact-card reveal reveal-delay-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <h4>Courriel</h4>
              <a href="mailto:contact@flexpad.com">contact@flexpad.com</a>
            </div>

            <div class="contact-card reveal reveal-delay-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              <h4>GitHub</h4>
              <a href="https://github.com/MathieuG8" target="_blank" rel="noopener">github.com/MathieuG8</a>
            </div>

            <div class="contact-card reveal reveal-delay-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <h4>Site web</h4>
              <a href="https://flexpad.vercel.app" target="_blank" rel="noopener">flexpad.vercel.app</a>
            </div>
          </div>
        </div>
      </div>

      <div class="back-link reveal">
        <a href="/">← Retour à l’accueil</a>
      </div>
    </main>
  </div>

</Layout>
