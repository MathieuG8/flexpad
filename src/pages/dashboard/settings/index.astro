---
import Layout from '../../../layouts/Layout.astro';
import DashboardChrome from '../../../components/DashboardChrome.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;

const session = await getSession(Astro.request);
if (!session?.user) {
  return Astro.redirect('/login?callbackUrl=/dashboard/settings');
}

const title = 'Paramètres | FlexPad';
const isAdmin = session.user.role === 'admin';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome
      variant="user"
      title="Paramètres du compte"
      subtitle="Informations liées à votre session FlexPad."
      userName={session.user.name ?? session.user.email ?? 'Utilisateur'}
      userEmail={session.user.email ?? ''}
      isAdmin={isAdmin}
    >
      <div class="dashboard-card reveal visible">
        <h2 class="dashboard-card__title">Profil</h2>
        <ul class="dashboard-meta">
          <li><span>ID</span> <code>{session.user.id}</code></li>
          <li><span>Nom</span> {session.user.name ?? '—'}</li>
          <li><span>Courriel</span> {session.user.email}</li>
          <li><span>Rôle</span> {session.user.role === 'admin' ? 'Administrateur' : 'Client'}</li>
        </ul>
        <p class="dashboard-note">
          La modification du mot de passe ou du courriel pourrait être ajoutée ici (flux sécurisé dédié).
        </p>
      </div>
    </DashboardChrome>
  </div>
</Layout>
