---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import AdminPlaceholder from '../../../../components/AdminPlaceholder.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');
const title = 'Admin — Produits | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Produits" subtitle="Catalogue et fiches articles." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <AdminPlaceholder title="Gestion du catalogue" body="La vitrine actuelle est statique (FlexPad). Une future CMS ou table produits alimenterait prix, médias et disponibilité." />
    </DashboardChrome>
  </div>
</Layout>
