---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import AdminPlaceholder from '../../../../components/AdminPlaceholder.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');
const title = 'Admin — Paramètres | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Paramètres administrateur" subtitle="Configuration globale du site." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <AdminPlaceholder title="Options boutique" body="Frais de port par défaut, devises, textes légaux, intégrations (Stripe, envoi courriel)." />
    </DashboardChrome>
  </div>
</Layout>
