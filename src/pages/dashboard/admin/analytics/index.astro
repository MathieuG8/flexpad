---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import AdminPlaceholder from '../../../../components/AdminPlaceholder.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');
const title = 'Admin — Analytique | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Analytique" subtitle="Trafic, conversion et entonnoir (à brancher sur un outil d’analyse)." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <AdminPlaceholder title="Tableaux de bord analytiques" body="Prévu pour de futurs graphiques (visites, panier moyen, sources). Pour l’instant, utilisez la vue d’ensemble admin et les commandes." />
    </DashboardChrome>
  </div>
</Layout>
