---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import AdminPlaceholder from '../../../../components/AdminPlaceholder.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');
const title = 'Admin — Coupons | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Coupons" subtitle="Codes promo et remises." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <AdminPlaceholder title="Codes promotionnels" body="Création et suivi de coupons (pourcentage, montant fixe, dates de validité) — à connecter au tunnel de commande." />
    </DashboardChrome>
  </div>
</Layout>
