---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import { getSession } from 'auth-astro/server';
import { db } from '../../../../db';
import { users } from '../../../../db/schema';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');

const allUsers = await db.select().from(users);
const title = 'Admin — Utilisateurs | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Utilisateurs" subtitle="Comptes enregistrés (Auth + base locale)." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <div class="dashboard-card reveal visible">
        <h2 class="dashboard-card__title">Liste ({allUsers.length})</h2>
        <div class="admin-users-table-wrap">
          <table class="admin-orders-table">
            <thead>
              <tr>
                <th>Courriel</th>
                <th>Nom</th>
                <th>Rôle</th>
                <th>Créé le</th>
              </tr>
            </thead>
            <tbody>
              {allUsers.map((u) => (
                <tr>
                  <td>{u.email}</td>
                  <td>{u.name ?? '—'}</td>
                  <td>{u.role === 'admin' ? 'Admin' : 'Client'}</td>
                  <td>{u.createdAt ? new Date(u.createdAt).toLocaleDateString('fr-CA') : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="dashboard-note">Promouvoir un compte en admin : mettre à jour la colonne <code>role</code> à <code>admin</code> en base (puis reconnecter).</p>
      </div>
    </DashboardChrome>
  </div>
</Layout>
