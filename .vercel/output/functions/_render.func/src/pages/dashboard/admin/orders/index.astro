---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import { getSession } from 'auth-astro/server';
import { desc, eq } from 'drizzle-orm';
import { db } from '../../../../db';
import { orders, users } from '../../../../db/schema';
import { formatCadFromCents } from '../../../../lib/orders';
import type { CartLine } from '../../../../lib/orders';

export const prerender = false;

const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const rows = await db
  .select({
    order: orders,
    customerEmail: users.email,
    customerName: users.name,
  })
  .from(orders)
  .leftJoin(users, eq(orders.userId, users.id))
  .orderBy(desc(orders.createdAt));

function parseItems(json: string): CartLine[] {
  try {
    const o = JSON.parse(json) as { items?: CartLine[] };
    return Array.isArray(o.items) ? o.items : [];
  } catch {
    return [];
  }
}

const title = 'Admin — Commandes | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome
      variant="admin"
      title="Gestion des commandes"
      subtitle="Modifier le statut met à jour la base locale."
      userName={session.user.name ?? session.user.email ?? 'Admin'}
      userEmail={session.user.email ?? ''}
      isAdmin={true}
    >
      {rows.length === 0 ? (
        <p class="dashboard-note">Aucune commande.</p>
      ) : (
        <div class="admin-orders-wrap" id="admin-orders-root">
          <table class="admin-orders-table">
            <thead>
              <tr>
                <th>Référence</th>
                <th>Client</th>
                <th>Total</th>
                <th>Statut</th>
              </tr>
            </thead>
            <tbody>
              {rows.map(({ order: o, customerEmail, customerName }) => {
                const items = parseItems(o.cartJson);
                const qty = items.reduce((n, i) => n + (i.quantity ?? 0), 0);
                return (
                  <tr data-order-id={o.id}>
                    <td>
                      <strong>{o.reference}</strong>
                      <div class="admin-orders-sub">
                        {qty} art. ·{' '}
                        {o.createdAt
                          ? new Date(o.createdAt).toLocaleString('fr-CA')
                          : ''}
                      </div>
                    </td>
                    <td>
                      {customerName ?? '—'}
                      <div class="admin-orders-sub">{customerEmail ?? o.userId}</div>
                    </td>
                    <td>{formatCadFromCents(o.totalCents)}</td>
                    <td>
                      <select class="admin-order-status form-control-like" data-order-id={o.id} aria-label={`Statut ${o.reference}`}>
                        <option value="confirmed" selected={o.status === 'confirmed'}>Confirmée</option>
                        <option value="processing" selected={o.status === 'processing'}>En traitement</option>
                        <option value="shipped" selected={o.status === 'shipped'}>Expédiée</option>
                        <option value="cancelled" selected={o.status === 'cancelled'}>Annulée</option>
                      </select>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </DashboardChrome>
  </div>
</Layout>

<script>
  document.getElementById('admin-orders-root')?.addEventListener('change', async (e) => {
    const t = e.target;
    if (!t || !t.classList.contains('admin-order-status')) return;
    const orderId = t.getAttribute('data-order-id');
    const status = t.value;
    if (!orderId) return;
    try {
      const res = await fetch('/api/admin/order-status', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId, status }),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        alert(j.error || 'Mise à jour impossible');
      }
    } catch (err) {
      console.error(err);
      alert('Erreur réseau');
    }
  });
</script>
