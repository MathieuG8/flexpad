---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import AdminPlaceholder from '../../../../components/AdminPlaceholder.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');
const title = 'Admin — Avis | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Avis clients" subtitle="Modération et réponses." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <AdminPlaceholder title="Avis et notes" body="Table d’avis vérifiés, signalement et publication — à lier à une table reviews en base." />
    </DashboardChrome>
  </div>
</Layout>
