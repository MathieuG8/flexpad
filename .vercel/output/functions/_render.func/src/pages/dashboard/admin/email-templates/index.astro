---
import Layout from '../../../../layouts/Layout.astro';
import DashboardChrome from '../../../../components/DashboardChrome.astro';
import AdminPlaceholder from '../../../../components/AdminPlaceholder.astro';
import { getSession } from 'auth-astro/server';

export const prerender = false;
const session = await getSession(Astro.request);
if (!session?.user || session.user.role !== 'admin') return Astro.redirect('/dashboard');
const title = 'Admin — Modèles courriel | FlexPad';
---

<Layout {title} site>
  <div class="page-content dashboard-page dashboard-page--chrome">
    <DashboardChrome variant="admin" title="Modèles courriel" subtitle="Confirmation de commande, expédition, etc." userName={session.user.name ?? session.user.email ?? 'Admin'} userEmail={session.user.email ?? ''} isAdmin={true}>
      <AdminPlaceholder title="Éditeur de modèles" body="Prévu pour personnaliser les courriels transactionnels (MJML/HTML, variables dynamiques)." />
    </DashboardChrome>
  </div>
</Layout>
