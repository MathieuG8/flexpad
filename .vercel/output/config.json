{
	"version": 3,
	"routes": [
		{
			"src": "^/assets/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/order-status\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth(?:\\/(.*?))?\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/orders\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/analytics\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/categories\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/coupons\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/email-templates\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/logs\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/notifications\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/orders\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/products\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/reports\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/reviews\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/settings\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/users\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/admin\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/orders\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/settings\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/wishlist\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/dashboard\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/login\\/?$",
			"dest": "_render"
		}
	]
}