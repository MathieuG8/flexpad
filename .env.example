# Renommer ce fichier en .env à la racine du projet (obligatoire pour la session Auth.js).
# Ne pas committer .env.
#
# Générer une valeur aléatoire (32+ caractères), ex. :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Base PostgreSQL (obligatoire) — Vercel : Storage / Marketplace → Neon (plan gratuit) → copier DATABASE_URL.
# En local : même URL que ton projet Neon, ou une base Postgres locale (postgresql://…).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# --- Schéma + comptes : avec DATABASE_URL défini ---
#   pnpm db:push    # crée / met à jour les tables
#   pnpm db:seed    # comptes démo + admin (lit ce fichier automatiquement)

# --- Seed : pnpm run db:seed lit automatiquement ce fichier (pas besoin de "set" dans le terminal) ---
# Compte démo : SEED_EMAIL, SEED_PASSWORD, SEED_NAME — SEED_ROLE=admin|user (défaut : user)
# Compte admin : ADMIN_EMAIL, ADMIN_PASSWORD, ADMIN_NAME (sinon défaut admin@flexpad.local / flexpad-admin)
# Si ADMIN_EMAIL existe déjà : ADMIN_UPSERT=true pour forcer la mise à jour du mot de passe et du rôle admin.

# ADMIN_EMAIL=toi@exemple.com
# ADMIN_PASSWORD=ton_mot_de_passe
# ADMIN_NAME=Prénom Nom
# ADMIN_UPSERT=true

# PowerShell (si tu préfères le terminal au lieu du fichier .env) — utiliser $env:, pas "set" :
#   $env:ADMIN_EMAIL = "toi@exemple.com"
#   $env:ADMIN_PASSWORD = "secret"
#   $env:ADMIN_NAME = "Prénom Nom"
#   pnpm run db:seed
